{% extends 'base.html.twig' %}
{% block title %}Espace Agent{% endblock %}

{% block body %}
<div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Bonjour, {{ app.user.firstName }} 👋</h1>
    <p class="text-gray-500 mt-1">Voici l'état de la file d'attente</p>
</div>

{# ── Cartes KPI ── #}
<div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-blue-100 p-5 text-center">
        <p class="text-3xl font-bold text-blue-700 mb-1">{{ openCount }}</p>
        <p class="text-xs font-semibold text-blue-500 uppercase tracking-wider">Ouverts</p>
    </div>
    <div class="bg-white rounded-xl border border-yellow-100 p-5 text-center">
        <p class="text-3xl font-bold text-yellow-700 mb-1">{{ inProgressCount }}</p>
        <p class="text-xs font-semibold text-yellow-500 uppercase tracking-wider">En cours</p>
    </div>
    <div class="bg-white rounded-xl border border-green-100 p-5 text-center">
        <p class="text-3xl font-bold text-green-700 mb-1">{{ resolvedCount }}</p>
        <p class="text-xs font-semibold text-green-500 uppercase tracking-wider">Résolus</p>
    </div>
</div>

{# ── Mes tickets assignés ── #}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700">
            Mes tickets assignés
            {% if assignedTickets|length > 0 %}
                <span class="ml-2 text-xs bg-blue-100 text-blue-600 px-2 py-0.5 rounded-full">
                    {{ assignedTickets|length }}
                </span>
            {% endif %}
        </h2>
        <a href="{{ path('app_ticket_user_tickets') }}"
           class="text-xs text-blue-600 hover:underline">Tous les tickets →</a>
    </div>

    {% if assignedTickets is empty %}
        <div class="p-10 text-center">
            <svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <p class="text-gray-400 text-sm">Aucun ticket assigné.</p>
            <a href="{{ path('app_ticket_user_tickets') }}"
               class="inline-block mt-3 text-sm text-blue-600 hover:underline">
                Voir les tickets disponibles
            </a>
        </div>
    {% else %}
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ticket</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Priorité</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Créé le</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {% for ticket in assignedTickets %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 text-gray-400 font-mono text-xs">#{{ ticket.id }}</td>
                    <td class="px-4 py-3">
                        <a href="{{ path('app_ticket_show', {id: ticket.id}) }}"
                           class="font-medium text-gray-800 hover:text-blue-600 transition-colors">
                            {{ ticket.title }}
                        </a>
                        <div class="text-xs text-gray-400 mt-0.5">par {{ ticket.creator.fullName }}</div>
                    </td>
                    <td class="px-4 py-3 hidden sm:table-cell">
                        {% include 'ticket/_badge_priority.html.twig' with {priority: ticket.priority} %}
                    </td>
                    <td class="px-4 py-3">
                        {% include 'ticket/_badge_status.html.twig' with {status: ticket.status} %}
                    </td>
                    <td class="px-4 py-3 text-gray-400 text-xs hidden md:table-cell">
                        {{ ticket.createdAt|date('d/m/Y') }}
                    </td>
                    <td class="px-4 py-3 text-right">
                        <a href="{{ path('app_ticket_show', {id: ticket.id}) }}"
                           class="text-blue-600 hover:text-blue-800 text-xs font-medium">
                            Traiter →
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
