{% extends 'base.html.twig' %}
{% block title %}Ticket #{{ ticket.id }} — {{ ticket.title }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">

    {# En-tête #}
    <div class="mb-6">
        <a href="{{ path('app_ticket_user_tickets') }}"
           class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3">
            ← Retour aux tickets
        </a>
        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">{{ ticket.title }}</h1>
                <div class="flex flex-wrap items-center gap-2 mt-2">
                    <span class="text-xs text-gray-400 font-mono">Ticket #{{ ticket.id }}</span>
                    {% include 'ticket/_badge_status.html.twig' with {status: ticket.status} %}
                    {% include 'ticket/_badge_priority.html.twig' with {priority: ticket.priority} %}
                </div>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
            <div class="flex gap-2 shrink-0">
                <a href="{{ path('app_ticket_edit', {id: ticket.id}) }}"
                   class="px-3 py-1.5 text-xs font-medium bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition-colors">
                    Modifier
                </a>
                <form method="post" action="{{ path('app_ticket_delete', {id: ticket.id}) }}"
                      onsubmit="return confirm('Supprimer définitivement ce ticket et toutes ses réponses ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_ticket_' ~ ticket.id) }}">
                    <button type="submit"
                            class="px-3 py-1.5 text-xs font-medium bg-red-50 hover:bg-red-100 text-red-600 rounded-lg transition-colors">
                        Supprimer
                    </button>
                </form>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# ── Colonne principale ── #}
        <div class="lg:col-span-2 space-y-6">

            {# Description originale du ticket #}
            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-600 shrink-0">
                        {{ ticket.creator.firstName|first }}{{ ticket.creator.lastName|first }}
                    </div>
                    <div>
                        <span class="text-sm font-medium text-gray-800">{{ ticket.creator.fullName }}</span>
                        <span class="text-xs text-gray-400 ml-2">{{ ticket.createdAt|date('d/m/Y à H:i') }}</span>
                    </div>
                </div>
                <p class="text-gray-700 text-sm leading-relaxed whitespace-pre-line">{{ ticket.description }}</p>
            </div>

            {# Fil des réponses #}
            {% if ticket.responses|length > 0 %}
            <div class="space-y-4">
                {% for response in ticket.responses %}
                    {% set isAgent = response.author.isAgent() %}
                    <div class="bg-white rounded-xl border {{ isAgent ? 'border-blue-100 bg-blue-50/30' : 'border-gray-200' }} p-5">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold shrink-0
                                {{ isAgent ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600' }}">
                                {{ response.author.firstName|first }}{{ response.author.lastName|first }}
                            </div>
                            <div class="flex-1">
                                <span class="text-sm font-medium text-gray-800">{{ response.author.fullName }}</span>
                                {% if isAgent %}
                                    <span class="ml-2 text-xs bg-blue-100 text-blue-600 px-2 py-0.5 rounded-full font-medium">Agent</span>
                                {% endif %}
                            </div>
                            <span class="text-xs text-gray-400">{{ response.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line ml-12">{{ response.content }}</p>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            {# Formulaire de réponse #}
            {% if responseForm %}
            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <h3 class="text-sm font-semibold text-gray-700 mb-4">
                    {% if is_granted('ROLE_AGENT') %}Répondre en tant qu'agent{% else %}Ajouter une réponse{% endif %}
                </h3>

                {{ form_start(responseForm, {attr: {class: 'space-y-4'}}) }}
                    {{ form_widget(responseForm.content, {attr: {
                        class: 'w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none',
                        rows: 4
                    }}) }}
                    <div class="text-red-500 text-xs">{{ form_errors(responseForm.content) }}</div>

                    <div class="flex flex-wrap items-center justify-between gap-3">
                        {# Option "résoudre en même temps" — agents uniquement #}
                        {% if is_granted('ROLE_AGENT') and ticket.status.value != 'resolved' %}
                        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                            <input type="checkbox" name="close_ticket" value="1"
                                   class="h-4 w-4 text-green-600 border-gray-300 rounded">
                            Marquer comme résolu
                        </label>
                        {% else %}
                        <span></span>
                        {% endif %}

                        <button type="submit"
                                class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors">
                            Envoyer la réponse
                        </button>
                    </div>
                {{ form_end(responseForm) }}
            </div>
            {% elseif ticket.isClosed() %}
            <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-center text-sm text-gray-500">
                Ce ticket est fermé. Aucune réponse ne peut être ajoutée.
            </div>
            {% endif %}

        </div>

        {# ── Colonne latérale ── #}
        <div class="space-y-4">

            {# Informations du ticket #}
            <div class="bg-white rounded-xl border border-gray-200 p-5">
                <h3 class="text-sm font-semibold text-gray-700 mb-4">Informations</h3>
                <dl class="space-y-3 text-sm">
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Créé par</dt>
                        <dd class="text-gray-700 font-medium mt-0.5">{{ ticket.creator.fullName }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Agent assigné</dt>
                        <dd class="mt-0.5">
                            {% if ticket.assignedAgent %}
                                <span class="text-gray-700 font-medium">{{ ticket.assignedAgent.fullName }}</span>
                            {% else %}
                                <span class="text-gray-400 italic">Non assigné</span>
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Créé le</dt>
                        <dd class="text-gray-600 mt-0.5">{{ ticket.createdAt|date('d/m/Y à H:i') }}</dd>
                    </div>
                    {% if ticket.updatedAt %}
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Dernière mise à jour</dt>
                        <dd class="text-gray-600 mt-0.5">{{ ticket.updatedAt|date('d/m/Y à H:i') }}</dd>
                    </div>
                    {% endif %}
                    {% if ticket.resolvedAt %}
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Résolu le</dt>
                        <dd class="text-green-600 font-medium mt-0.5">{{ ticket.resolvedAt|date('d/m/Y à H:i') }}</dd>
                    </div>
                    {% endif %}
                    <div>
                        <dt class="text-xs text-gray-400 uppercase tracking-wider">Réponses</dt>
                        <dd class="text-gray-700 font-medium mt-0.5">{{ ticket.responses|length }}</dd>
                    </div>
                </dl>
            </div>

            {# Assignation — agents non encore assignés #}
            {% if is_granted('ROLE_AGENT') and not ticket.assignedAgent and not ticket.isClosed() %}
            <div class="bg-white rounded-xl border border-gray-200 p-5">
                <h3 class="text-sm font-semibold text-gray-700 mb-3">Assignation</h3>
                <form method="post" action="{{ path('app_ticket_assign', {id: ticket.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('assign_ticket_' ~ ticket.id) }}">
                    <button type="submit"
                            class="w-full py-2 px-4 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors">
                        M'assigner ce ticket
                    </button>
                </form>
            </div>
            {% elseif is_granted('ROLE_AGENT') and ticket.assignedAgent and ticket.assignedAgent.id == app.user.id %}
            <div class="bg-blue-50 rounded-xl border border-blue-100 p-4 text-sm text-blue-700 flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Vous êtes assigné à ce ticket
            </div>
            {% endif %}

            {# Changement de statut — agents/admins #}
            {% if statusForm %}
            <div class="bg-white rounded-xl border border-gray-200 p-5">
                <h3 class="text-sm font-semibold text-gray-700 mb-3">Changer le statut</h3>
                {{ form_start(statusForm, {attr: {class: 'space-y-3'}}) }}
                    {{ form_widget(statusForm.status, {attr: {class: 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white'}}) }}
                    <button type="submit"
                            class="w-full py-2 px-4 bg-gray-800 hover:bg-gray-900 text-white text-sm font-medium rounded-lg transition-colors">
                        Mettre à jour
                    </button>
                {{ form_end(statusForm) }}
            </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
