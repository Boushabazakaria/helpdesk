{% set colors = {
    'open':        'bg-blue-100 text-blue-700',
    'in_progress': 'bg-yellow-100 text-yellow-700',
    'resolved':    'bg-green-100 text-green-700',
    'closed':      'bg-gray-100 text-gray-600',
} %}
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ colors[status.value] ?? 'bg-gray-100 text-gray-600' }}">
    {{ status.getLabel() }}
</span>
