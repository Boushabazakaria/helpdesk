{% extends 'base.html.twig' %}
{% block title %}Nouveau ticket{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_ticket_user_tickets') }}"
           class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-3">
            ← Retour aux tickets
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Nouveau ticket</h1>
        <p class="text-gray-500 text-sm mt-1">Décrivez votre problème, un agent vous répondra dès que possible.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.title, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.title, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(form.title) }}</div>
            </div>

            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.description, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(form.description) }}</div>
            </div>

            <div>
                {{ form_label(form.priority, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.priority, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(form.priority) }}</div>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors">
                    Soumettre le ticket
                </button>
                <a href="{{ path('app_ticket_user_tickets') }}"
                   class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
