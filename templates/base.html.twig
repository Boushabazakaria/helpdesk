<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Helpdesk{% endblock %}</title>

    {# Tailwind CSS via CDN — aucun build Node.js requis #}
    <script src="https://cdn.tailwindcss.com"></script>

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 min-h-screen">

{% if app.user %}
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 text-blue-600 font-bold text-xl">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                        </svg>
                        Helpdesk
                    </a>

                    <div class="hidden md:flex ml-10 space-x-1">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}"
                               class="px-3 py-2 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                                Dashboard
                            </a>
                        {% endif %}

                        {% if is_granted('ROLE_AGENT') %}
                            <a href="{{ path('app_agent_dashboard') }}"
                               class="px-3 py-2 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                                Tous les tickets
                            </a>
                        {% endif %}

                        <a href="{{ path('app_user_tickets') }}"
                           class="px-3 py-2 rounded-md text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors">
                            Mes tickets
                        </a>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-500 hidden sm:block">
                        {{ app.user.fullName }}
                        <span class="ml-1 text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-medium">
                            {% if is_granted('ROLE_ADMIN') %}Admin
                            {% elseif is_granted('ROLE_AGENT') %}Agent
                            {% else %}Utilisateur{% endif %}
                        </span>
                    </span>
                    <a href="{{ path('app_logout') }}"
                       class="text-sm font-medium text-gray-500 hover:text-red-600 transition-colors flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </nav>
{% endif %}

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg border flex items-center gap-2
                {% if type == 'success' %}bg-green-50 border-green-200 text-green-800
                {% elseif type == 'error' %}bg-red-50 border-red-200 text-red-800
                {% elseif type == 'warning' %}bg-yellow-50 border-yellow-200 text-yellow-800
                {% else %}bg-blue-50 border-blue-200 text-blue-800{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{% block javascripts %}{% endblock %}
</body>
</html>
